generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model public__migrations {
  id         Int       @id @default(dbgenerated("nextval('_migrations_id_seq'::regclass)"))
  name       String    @unique @db.VarChar(255)
  applied_at DateTime? @default(now()) @db.Timestamp(6)

  @@map("_migrations")
}

model refresh_tokens {
  id          Int      @id @default(autoincrement())
  token       String   @unique
  user_id     Int
  is_revoked  Boolean  @default(false)
  expires_at  DateTime @db.Timestamp(6)
  created_at  DateTime @default(now()) @db.Timestamp(6)
  replaced_by String?  @db.VarChar(255)
  users       users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id], map: "idx_refresh_tokens_user")
  @@index([token], map: "idx_refresh_tokens_token")
}

model access_logs {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gate_id        String?         @db.Uuid
  plate_number   String?         @db.VarChar(20)
  vehicle_type   String?         @db.VarChar(50)
  access_granted Boolean?        @default(false)
  scan_image_url String?
  timestamp      DateTime?       @default(now()) @db.Timestamp(6)
  security_gates security_gates? @relation(fields: [gate_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model admissions {
  id                        Int                         @id @default(autoincrement())
  patient_id                String?                     @db.Uuid
  ward                      String?                     @db.VarChar(50)
  bed_number                String?                     @db.VarChar(20)
  status                    String?                     @default("Admitted") @db.VarChar(20)
  admission_date            DateTime?                   @default(now()) @db.Timestamp(6)
  discharge_date            DateTime?                   @db.Timestamp(6)
  hospital_id               Int?
  current_diet              String?                     @default("Normal") @db.VarChar(50)
  last_round_at             DateTime?                   @db.Timestamp(6)
  ipd_number                String?                     @db.VarChar(50)
  deleted_at                DateTime?                   @db.Timestamp(6)
  deleted_by                Int?
  deletion_reason           String?
  payment_mode              String?                     @default("SELF_PAY") @db.VarChar(20)
  pmjay_verified            Boolean?                    @default(false)
  pmjay_beneficiary_id      String?                     @db.VarChar(50)
  pmjay_package_code        String?                     @db.VarChar(20)
  pmjay_package_rate        Decimal?                    @db.Decimal(10, 2)
  pmjay_preauth_id          String?                     @db.VarChar(50)
  pmjay_preauth_status      String?                     @db.VarChar(20)
  pmjay_claim_id            String?                     @db.VarChar(50)
  hospitals                 hospitals?                  @relation(fields: [hospital_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  patients                  patients?                   @relation(fields: [patient_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  bed_history               bed_history[]
  care_tasks                care_tasks[]
  clinical_alerts           clinical_alerts[]
  clinical_tasks            clinical_tasks[]
  consumable_usage          consumable_usage[]
  discharge_plans           discharge_plans[]
  equipment_assignments     equipment_assignments[]
  equipment_requests        equipment_requests[]
  fall_risk_assessments     fall_risk_assessments[]
  fluid_balance             fluid_balance[]
  invoices                  invoices[]
  iv_lines                  iv_lines[]
  lab_orders                lab_orders[]
  lab_requests              lab_requests[]
  medication_administration medication_administration[]
  nurse_care_tasks          nurse_care_tasks[]
  pain_assessments          pain_assessments[]
  pain_scores               pain_scores[]
  patient_care_plans        patient_care_plans[]
  patient_consumables       patient_consumables[]
  patient_service_charges   patient_service_charges[]
  pending_charges           pending_charges[]
  pharmacy_orders           pharmacy_orders[]
  pmjay_claims              pmjay_claims[]
  pmjay_package_usage       pmjay_package_usage[]
  preauth_requests          preauth_requests[]
  radiology_orders          radiology_orders[]
  round_notes               round_notes[]
  shift_handoff_notes       shift_handoff_notes[]
  soap_notes                soap_notes[]
  vitals_logs               vitals_logs[]
  wound_assessments         wound_assessments[]

  @@unique([ipd_number, hospital_id], map: "idx_admissions_ipd_number_hospital")
  @@index([hospital_id], map: "idx_admissions_hospital_id")
  @@index([last_round_at], map: "idx_admissions_last_round")
  @@index([patient_id], map: "idx_admissions_patient_id")
  @@index([status], map: "idx_admissions_status")
  @@index([ward], map: "idx_admissions_ward")
  @@index([hospital_id, status, admission_date(sort: Desc)], map: "idx_admissions_hospital_status")
}

model ai_billing_predictions {
  id                Int       @id @default(autoincrement())
  model_name        String?   @db.VarChar(50)
  model_version     String?   @db.VarChar(20)
  prediction_type   String?   @db.VarChar(50)
  prediction_result Json?
  confidence_score  Decimal?  @db.Decimal(5, 2)
  created_at        DateTime? @default(now()) @db.Timestamp(6)

  @@index([prediction_type], map: "idx_ai_billing_type")
}

model anaesthesia_charts {
  id              Int          @id @default(autoincrement())
  surgery_id      Int?
  anaesthetist_id Int?
  start_time      DateTime?    @default(now()) @db.Timestamp(6)
  end_time        DateTime?    @db.Timestamp(6)
  technique       String?      @db.VarChar(100)
  notes           String?
  created_at      DateTime?    @default(now()) @db.Timestamp(6)
  drug_logs       drug_logs[]
  vital_logs      vital_logs[]
}

model api_usage_stats {
  id           Int        @id @default(autoincrement())
  hospital_id  Int?
  endpoint     String     @db.VarChar(255)
  method       String     @db.VarChar(10)
  count        Int?       @default(0)
  period_start DateTime   @db.Timestamptz(6)
  hospitals    hospitals? @relation(fields: [hospital_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([hospital_id, endpoint, method, period_start])
  @@index([hospital_id], map: "idx_api_usage_hospital")
  @@index([period_start], map: "idx_api_usage_period")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model app_build_history {
  id                  Int                  @id @default(autoincrement())
  build_config_id     Int?
  triggered_by        Int?
  trigger_reason      String?              @default("manual") @db.VarChar(50)
  github_run_id       String?              @db.VarChar(100)
  status              String?              @db.VarChar(20)
  started_at          DateTime?            @default(now()) @db.Timestamp(6)
  completed_at        DateTime?            @db.Timestamp(6)
  duration_seconds    Int?
  apk_url             String?
  error_message       String?
  created_at          DateTime?            @default(now()) @db.Timestamp(6)
  hospital_app_builds hospital_app_builds? @relation(fields: [build_config_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users               users?               @relation(fields: [triggered_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([build_config_id], map: "idx_build_history_config")
}

model appointments {
  id                                   Int         @id @default(autoincrement())
  patient_id                           String?     @db.Uuid
  doctor_id                            Int?
  appointment_date                     DateTime    @db.Date
  appointment_time                     DateTime?   @db.Time(6)
  slot_id                              Int?
  department                           String?     @db.VarChar(100)
  status                               String?     @default("Scheduled") @db.VarChar(50)
  reason                               String?
  notes                                String?
  created_by                           Int?
  created_at                           DateTime?   @default(now()) @db.Timestamp(6)
  updated_at                           DateTime?   @default(now()) @db.Timestamp(6)
  hospital_id                          Int?
  users_appointments_created_byTousers users?      @relation("appointments_created_byTousers", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_appointments_doctor_idTousers  users?      @relation("appointments_doctor_idTousers", fields: [doctor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  hospitals                            hospitals?  @relation(fields: [hospital_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  patients                             patients?   @relation(fields: [patient_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  opd_queue                            opd_queue[]

  @@index([appointment_date], map: "idx_appointments_date")
  @@index([doctor_id], map: "idx_appointments_doctor")
  @@index([hospital_id], map: "idx_appointments_hospital_id")
  @@index([patient_id], map: "idx_appointments_patient")
  @@index([hospital_id, appointment_date, status], map: "idx_appointments_hospital_date")
}

model audit_logs {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     Int?
  user_name   String?   @db.VarChar(255)
  action      String    @db.VarChar(50)
  entity_type String    @db.VarChar(50)
  entity_id   String?   @db.VarChar(50)
  details     Json?
  ip_address  String?   @db.VarChar(45)
  hospital_id Int?
  created_at  DateTime? @default(now()) @db.Timestamptz(6)

  @@index([action], map: "idx_audit_logs_action")
  @@index([created_at], map: "idx_audit_logs_created_at")
  @@index([hospital_id], map: "idx_audit_logs_hospital_id")
  @@index([user_id], map: "idx_audit_logs_user_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model bed_history {
  id           Int         @id @default(autoincrement())
  admission_id Int?
  ward         String?     @db.VarChar(50)
  bed_number   String?     @db.VarChar(20)
  action       String?     @db.VarChar(20)
  timestamp    DateTime?   @default(now()) @db.Timestamp(6)
  end_time     DateTime?   @db.Timestamp(6)
  hospital_id  Int?
  admissions   admissions? @relation(fields: [admission_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  hospitals    hospitals?  @relation(fields: [hospital_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([admission_id], map: "idx_bed_history_admission")
  @@index([admission_id], map: "idx_bed_history_admission_id")
  @@index([hospital_id], map: "idx_bed_history_hospital_id")
}

model beds {
  id                   Int        @id @default(autoincrement())
  ward_id              Int?
  bed_number           String     @db.VarChar(50)
  bed_type             String?    @default("Standard") @db.VarChar(50)
  status               String?    @default("Available") @db.VarChar(50)
  daily_rate           Decimal?   @default(0) @db.Decimal(10, 2)
  features             Json?      @default("{}")
  current_admission_id Int?
  is_active            Boolean?   @default(true)
  created_at           DateTime?  @default(now()) @db.Timestamp(6)
  hospital_id          Int?
  hospitals            hospitals? @relation(fields: [hospital_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  wards                wards?     @relation(fields: [ward_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([hospital_id], map: "idx_beds_hospital")
  @@index([status], map: "idx_beds_status")
  @@index([ward_id], map: "idx_beds_ward")
}

model billing_kpis {
  id                     Int       @id @default(autoincrement())
  kpi_date               DateTime? @default(dbgenerated("CURRENT_DATE")) @db.Date
  total_claims_submitted Int?      @default(0)
  clean_claims           Int?      @default(0)
  denied_claims          Int?      @default(0)
  ar_0_30                Decimal?  @default(0) @db.Decimal(12, 2)
  ar_31_60               Decimal?  @default(0) @db.Decimal(12, 2)
  ar_61_90               Decimal?  @default(0) @db.Decimal(12, 2)
  ar_over_90             Decimal?  @default(0) @db.Decimal(12, 2)
  collection_rate        Decimal?  @default(0) @db.Decimal(5, 2)
  created_at             DateTime? @default(now()) @db.Timestamp(6)
}

model blood_component_types {
  id               Int              @id @default(autoincrement())
  name             String           @db.VarChar(100)
  code             String           @db.VarChar(20)
  shelf_life_days  Int?             @default(35)
  storage_temp_min Decimal?         @db.Decimal(5, 2)
  storage_temp_max Decimal?         @db.Decimal(5, 2)
  is_active        Boolean?         @default(true)
  hospital_id      Int?
  blood_requests   blood_requests[]
  blood_units      blood_units[]
}

model blood_cross_matches {
  id                     Int                  @id @default(autoincrement())
  request_id             Int?
  unit_id                Int?
  patient_id             Int?
  patient_sample_id      String?              @db.VarChar(50)
  performed_by           Int?
  performed_at           DateTime?            @default(now()) @db.Timestamp(6)
  method                 String?              @db.VarChar(50)
  immediate_spin         String?              @db.VarChar(20)
  incubation_37c         String?              @db.VarChar(20)
  ags_phase              String?              @db.VarChar(20)
  result                 String?              @db.VarChar(50)
  antibody_detected      Boolean?
  reaction_strength      String?              @db.VarChar(20)
  ai_compatibility_score Int?
  interpretation         String?
  valid_until            DateTime?            @db.Timestamp(6)
  hospital_id            Int?
  blood_requests         blood_requests?      @relation(fields: [request_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  blood_units            blood_units?         @relation(fields: [unit_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  blood_transfusions     blood_transfusions[]
}

model blood_donation_campaigns {
  id                                                   Int       @id @default(autoincrement())
  campaign_name                                        String    @db.VarChar(100)
  campaign_type                                        String?   @default("Camp") @db.VarChar(50)
  location                                             String?
  address                                              String?
  city                                                 String?   @db.VarChar(50)
  start_date                                           DateTime  @db.Date
  end_date                                             DateTime  @db.Date
  start_time                                           DateTime? @db.Time(6)
  end_time                                             DateTime? @db.Time(6)
  target_units                                         Int?      @default(50)
  collected_units                                      Int?      @default(0)
  registered_donors                                    Int?      @default(0)
  deferred_donors                                      Int?      @default(0)
  organizer_name                                       String?   @db.VarChar(100)
  organizer_contact                                    String?   @db.VarChar(15)
  coordinator_id                                       Int?
  equipment_list                                       Json?
  staff_assigned                                       Json?
  status                                               String?   @default("Planned") @db.VarChar(20)
  notes                                                String?
  created_by                                           Int?
  created_at                                           DateTime? @default(now()) @db.Timestamp(6)
  users_blood_donation_campaigns_coordinator_idTousers users?    @relation("blood_donation_campaigns_coordinator_idTousers", fields: [coordinator_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_blood_donation_campaigns_created_byTousers     users?    @relation("blood_donation_campaigns_created_byTousers", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model blood_donors {
  id                      Int           @id @default(autoincrement())
  donor_id                String?       @unique @db.VarChar(50)
  name                    String        @db.VarChar(100)
  phone                   String        @db.VarChar(20)
  email                   String?       @db.VarChar(100)
  blood_group             String        @db.VarChar(5)
  rh_factor               String?       @default("Positive") @db.VarChar(10)
  date_of_birth           DateTime?     @db.Date
  gender                  String?       @db.VarChar(20)
  address                 String?
  city                    String?       @db.VarChar(100)
  weight                  Decimal?      @db.Decimal(5, 2)
  hemoglobin              Decimal?      @db.Decimal(5, 2)
  blood_pressure          String?       @db.VarChar(20)
  pulse                   Int?
  last_donation_date      DateTime?     @db.Date
  total_donations         Int?          @default(0)
  is_eligible             Boolean?      @default(true)
  is_voluntary            Boolean?      @default(true)
  deferral_reason         String?
  deferral_until          DateTime?     @db.Date
  medical_history         Json?         @default("{}")
  emergency_contact_name  String?       @db.VarChar(100)
  emergency_contact_phone String?       @db.VarChar(20)
  created_by              Int?
  created_at              DateTime?     @default(now()) @db.Timestamp(6)
  updated_at              DateTime?     @default(now()) @db.Timestamp(6)
  hospital_id             Int?
  blood_units             blood_units[]
}

model blood_exempt_conditions {
  id             Int      @id @default(autoincrement())
  condition_code String   @unique @db.VarChar(20)
  condition_name String   @db.VarChar(100)
  naco_mandate   Boolean? @default(true)
  is_active      Boolean? @default(true)
}

model blood_requests {
  id                         Int                          @id @default(autoincrement())
  request_id                 String?                      @db.VarChar(50)
  patient_id                 Int
  patient_blood_group        String?                      @db.VarChar(5)
  requested_by               Int?
  department                 String?                      @db.VarChar(100)
  ward_id                    Int?
  bed_number                 String?                      @db.VarChar(20)
  admission_id               Int?
  surgery_id                 Int?
  blood_group_required       String                       @db.VarChar(5)
  component_type_id          Int?
  units_required             Int?                         @default(1)
  units_issued               Int?                         @default(0)
  priority                   String?                      @default("Normal") @db.VarChar(20)
  indication                 String?
  diagnosis                  String?
  hemoglobin_level           Decimal?                     @db.Decimal(5, 2)
  platelet_count             Int?
  inr_value                  Decimal?                     @db.Decimal(5, 2)
  previous_transfusion       Boolean?                     @default(false)
  previous_reaction          Boolean?                     @default(false)
  reaction_history           String?
  cross_match_required       Boolean?                     @default(true)
  expected_date              DateTime?                    @db.Timestamp(6)
  urgency_notes              String?
  status                     String?                      @default("Pending") @db.VarChar(50)
  rejection_reason           String?
  approved_by                Int?
  approved_at                DateTime?                    @db.Timestamp(6)
  created_at                 DateTime?                    @default(now()) @db.Timestamp(6)
  updated_at                 DateTime?                    @default(now()) @db.Timestamp(6)
  hospital_id                Int?
  blood_cross_matches        blood_cross_matches[]
  blood_component_types      blood_component_types?       @relation(fields: [component_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  blood_transfusions         blood_transfusions[]
  surgery_blood_requirements surgery_blood_requirements[]
}

model blood_service_charges {
  id           Int       @id @default(autoincrement())
  service_code String    @unique @db.VarChar(20)
  service_name String    @db.VarChar(100)
  govt_fee     Decimal   @default(0) @db.Decimal(10, 2)
  private_fee  Decimal   @default(0) @db.Decimal(10, 2)
  is_active    Boolean?  @default(true)
  created_at   DateTime? @default(now()) @db.Timestamp(6)
  updated_at   DateTime? @default(now()) @db.Timestamp(6)
}

model blood_storage_equipment {
  id                    Int                     @id @default(autoincrement())
  equipment_id          String                  @unique @db.VarChar(20)
  name                  String                  @db.VarChar(100)
  type                  String                  @db.VarChar(50)
  location              String?                 @db.VarChar(100)
  temp_min              Decimal?                @db.Decimal(4, 1)
  temp_max              Decimal?                @db.Decimal(4, 1)
  current_temp          Decimal?                @db.Decimal(4, 1)
  capacity_units        Int?
  current_units         Int?                    @default(0)
  last_calibration      DateTime?               @db.Date
  next_calibration      DateTime?               @db.Date
  is_operational        Boolean?                @default(true)
  alarm_enabled         Boolean?                @default(true)
  alarm_triggered       Boolean?                @default(false)
  notes                 String?
  created_at            DateTime?               @default(now()) @db.Timestamp(6)
  blood_temperature_log blood_temperature_log[]
}

model blood_temperature_log {
  id                      Int                      @id @default(autoincrement())
  equipment_id            Int?
  temperature             Decimal                  @db.Decimal(4, 1)
  recorded_by             Int?
  is_automated            Boolean?                 @default(false)
  is_within_range         Boolean?                 @default(true)
  action_taken            String?
  recorded_at             DateTime?                @default(now()) @db.Timestamp(6)
  blood_storage_equipment blood_storage_equipment? @relation(fields: [equipment_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users                   users?                   @relation(fields: [recorded_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model blood_transfusions {
  id                    Int                     @id @default(autoincrement())
  transfusion_id        String?                 @db.VarChar(50)
  unit_id               Int?
  request_id            Int?
  cross_match_id        Int?
  patient_id            Int?
  administered_by       Int?
  ward_id               Int?
  bed_number            String?                 @db.VarChar(20)
  start_time            DateTime?               @db.Timestamp(6)
  end_time              DateTime?               @db.Timestamp(6)
  vitals_baseline       Json?                   @default("{}")
  vitals_15min          Json?                   @default("{}")
  vitals_30min          Json?                   @default("{}")
  vitals_1hour          Json?                   @default("{}")
  vitals_end            Json?                   @default("{}")
  rate_ml_per_hour      Int?
  volume_transfused     Int?
  reaction_occurred     Boolean?                @default(false)
  reaction_time         DateTime?               @db.Timestamp(6)
  reaction_type         String?                 @db.VarChar(100)
  reaction_severity     String?                 @db.VarChar(50)
  transfusion_stopped   Boolean?                @default(false)
  outcome               String?                 @db.VarChar(50)
  notes                 String?
  created_at            DateTime?               @default(now()) @db.Timestamp(6)
  updated_at            DateTime?               @default(now()) @db.Timestamp(6)
  hospital_id           Int?
  blood_cross_matches   blood_cross_matches?    @relation(fields: [cross_match_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  blood_requests        blood_requests?         @relation(fields: [request_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  blood_units           blood_units?            @relation(fields: [unit_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  transfusion_reactions transfusion_reactions[]
}

model blood_units {
  id                     Int                      @id @default(autoincrement())
  unit_id                String?                  @db.VarChar(50)
  bag_number             String?                  @db.VarChar(50)
  donor_id               Int?
  blood_group            String?                  @db.VarChar(5)
  rh_factor              String?                  @db.VarChar(10)
  component_type_id      Int?
  parent_unit_id         Int?
  volume_ml              Int?
  collection_date        DateTime?                @db.Date
  expiry_date            DateTime?                @db.Date
  collection_type        String?                  @default("Voluntary") @db.VarChar(50)
  storage_location       String?                  @db.VarChar(100)
  refrigerator_id        String?                  @db.VarChar(50)
  shelf_number           String?                  @db.VarChar(50)
  current_temperature    Decimal?                 @db.Decimal(5, 2)
  temperature_log        Json?                    @default("[]")
  status                 String?                  @default("Quarantine") @db.VarChar(50)
  tested_status          String?                  @default("Pending") @db.VarChar(50)
  tti_results            Json?                    @default("{}")
  blood_group_confirmed  Boolean?                 @default(false)
  special_testing        Json?                    @default("{}")
  reserved_for_patient   Int?
  reserved_until         DateTime?                @db.Timestamp(6)
  issued_to_patient      Int?
  issued_date            DateTime?                @db.Timestamp(6)
  issued_by              Int?
  discard_reason         String?
  discarded_by           Int?
  discarded_at           DateTime?                @db.Timestamp(6)
  notes                  String?
  created_by             Int?
  created_at             DateTime?                @default(now()) @db.Timestamp(6)
  updated_at             DateTime?                @default(now()) @db.Timestamp(6)
