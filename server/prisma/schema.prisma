  patient          patients          @relation(fields: [local_patient_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  master           master_identities @relation(fields: [master_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([master_id, local_patient_id], map: "idx_patient_links_unique")
  @@index([local_patient_id], map: "idx_patient_links_local")
  @@index([master_id], map: "idx_patient_links_master")
}

model payer_profiles {
  id              Int       @id @default(autoincrement())
  payer_name      String    @db.VarChar(100)
  payer_id        String    @unique @db.VarChar(50) // The 5-digit Payer ID (e.g. 00431)
  clearinghouse   String?   @db.VarChar(50)
  sftp_host       String?   @db.VarChar(100)
  sftp_username   String?   @db.VarChar(50)
  sftp_password   String?   @db.VarChar(255) // Encrypted
  is_active       Boolean?  @default(true)
  created_at      DateTime? @default(now()) @db.Timestamp(6)
}

model edi_transmissions {
  id              Int       @id @default(autoincrement())
  batch_id        String    @unique @db.VarChar(50) // Unique Trace Number
  type            String    @db.VarChar(10) // 837 (Claim) or 835 (Remit)
  status          String    @default("Generated") @db.VarChar(20)
  file_content    String?   @db.Text
  file_name       String?   @db.VarChar(100)
  record_count    Int?      @default(0)
  ack_status      String?   // 999 Acknowledgement status
  created_at      DateTime? @default(now()) @db.Timestamp(6)
  sent_at         DateTime? @db.Timestamp(6)
  hospital_id     Int?
  
  hospitals       hospitals? @relation(fields: [hospital_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  
  @@index([status], map: "idx_edi_status")
  @@index([type], map: "idx_edi_type")
}

// --- SPECIALTY MODULES (PHASE 3) ---

// Oncology: TNM Staging (Cancer staging)
model oncology_staging {
  id              Int       @id @default(autoincrement())
  patient_id      String    @db.Uuid
  diagnosis_date  DateTime  @db.Date
  cancer_type     String    @db.VarChar(100)
  location        String?   @db.VarChar(100)
  
  // TNM Classification
  tumor_size      String    @db.VarChar(10) // T1, T2, etc.
  node_involvement String   @db.VarChar(10) // N0, N1, etc.
  metastasis      String    @db.VarChar(10) // M0, M1, etc.
  stage_group     String    @db.VarChar(10) // Stage I, II, III, IV
  
  pathology_report Json?    // Structured findings
  noted_by        Int?
  created_at      DateTime? @default(now()) @db.Timestamp(6)
  
  patient         patients  @relation(fields: [patient_id], references: [id], onDelete: Cascade)
  users           users?    @relation(fields: [noted_by], references: [id])
}

// Oncology: Chemotherapy Cycle Management
model chemo_cycles {
  id              Int       @id @default(autoincrement())
  patient_id      String    @db.Uuid
  regimen_name    String    @db.VarChar(100) // e.g. "R-CHOP"
  cycle_number    Int       // 1, 2, 3...
  total_cycles    Int?
  start_date      DateTime  @db.Date
  end_date        DateTime? @db.Date
  status          String    @default("Active") @db.VarChar(20) // Active, Completed, On-Hold
  
  // Clinical Data
  bsa             Decimal?  @db.Decimal(5, 2) // Body Surface Area
  weight_kg       Decimal?  @db.Decimal(5, 2)
  height_cm       Decimal?  @db.Decimal(5, 2)
  
  sessions        chemo_sessions[]
  patient         patients  @relation(fields: [patient_id], references: [id], onDelete: Cascade)
  
  @@unique([patient_id, regimen_name, cycle_number])
}

model chemo_sessions {
  id              Int       @id @default(autoincrement())
  cycle_id        Int
  day_number      Int       // Day 1, Day 8, etc.
  scheduled_date  DateTime  @db.Date
  administered_date DateTime? @db.Timestamp(6)
  status          String    @default("Scheduled") @db.VarChar(20) // Scheduled, Administered, Skipped
  drugs_administered Json?  // List of drugs and dosages
  adverse_events  String?
  notes           String?
  administered_by Int?
  
  chemo_cycle     chemo_cycles @relation(fields: [cycle_id], references: [id], onDelete: Cascade)
  users           users?       @relation(fields: [administered_by], references: [id])
}

// Nephrology: Dialysis Sessions
model dialysis_sessions {
  id              Int       @id @default(autoincrement())
  patient_id      String    @db.Uuid
  hospital_id     Int
  session_date    DateTime  @db.Timestamp(6)
  start_time      DateTime  @db.Timestamp(6)
  end_time        DateTime? @db.Timestamp(6)
  
  // Machine Readings (IoT Integration points)
  machine_id      String?   @db.VarChar(50)
  access_site     String?   @db.VarChar(50) // AV Fistula, CVC
  pre_weight      Decimal   @db.Decimal(5, 2)
  post_weight     Decimal?  @db.Decimal(5, 2)
  fluid_removed   Decimal?  @db.Decimal(5, 2) // Liters
  blood_flow_rate Int?      // ml/min
  dialysate_flow  Int?      // ml/min
  kt_v            Decimal?  @db.Decimal(4, 2) // Adequacy
  
  complications   String?
  status          String    @default("Completed") @db.VarChar(20)
  performed_by    Int?
  
  current_admission_id Int? // If IPD patient
  
  patient         patients  @relation(fields: [patient_id], references: [id], onDelete: Cascade)
  hospitals       hospitals @relation(fields: [hospital_id], references: [id])
  users           users?    @relation(fields: [performed_by], references: [id])
}



model migration_jobs {
  id              Int       @id @default(autoincrement())
  filename        String    @db.VarChar(255)
  original_name   String    @db.VarChar(255)
  file_path       String
  status          String    @default("UPLOADED") @db.VarChar(50)
  total_rows      Int       @default(0)
  valid_rows      Int       @default(0)
  error_rows      Int       @default(0)
  mapping_config  Json?
  created_by      Int?
  created_at      DateTime? @default(now()) @db.Timestamp(6)
  updated_at      DateTime? @default(now()) @db.Timestamp(6)
  hospital_id     Int?
  // users relation removed to avoid modifying users model
  migration_errors migration_errors[]

  @@index([hospital_id], map: "idx_migration_jobs_hospital")
  @@index([status], map: "idx_migration_jobs_status")
}

model migration_errors {
  id              Int            @id @default(autoincrement())
  job_id          Int
  row_number      Int
  row_data        Json?
  error_message   String
  created_at      DateTime?      @default(now()) @db.Timestamp(6)
  migration_jobs  migration_jobs @relation(fields: [job_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([job_id], map: "idx_migration_errors_job")
}

model patient_consent_logs {
  id           Int       @id @default(autoincrement())
  patient_id   String    @db.Uuid
  consent_type String    @db.VarChar(100)
  status       String    @db.VarChar(50)
  version      String?   @db.VarChar(20)
  ip_address   String?   @db.VarChar(45)
  user_agent   String?
  granted_at   DateTime  @default(now()) @db.Timestamp(6)
  revoked_at   DateTime? @db.Timestamp(6)
  notes        String?
  hospital_id  Int?
  patients     patients  @relation(fields: [patient_id], references: [id], onDelete: Cascade)

  @@index([patient_id], map: "idx_consent_patient")
  @@index([granted_at], map: "idx_consent_date")
}

model data_anonymization_logs {
  id          Int      @id @default(autoincrement())
  entity_type String   @db.VarChar(50)
  entity_id   String   @db.VarChar(100)
  action      String   @default("ANONYMIZED")
  reason      String?
  executed_at DateTime @default(now())
  details     Json?
}
