# ============================================
# WOLF HMS - Environment Configuration
# ============================================
# SECURITY WARNING: Never commit .env files with real credentials!
# Copy this to .env and fill in your values.

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_USER=postgres
DB_HOST=localhost
DB_NAME=hospital_db
DB_PASSWORD=your_secure_password
DB_PORT=5432

# Full connection string (alternative to individual params)
# DATABASE_URL=postgresql://user:password@host:port/database

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=8080
NODE_ENV=development

# ============================================
# SECURITY [CRITICAL]
# ============================================
# JWT_SECRET: MUST be a strong, random string (minimum 32 characters)
# Generate with: openssl rand -base64 48
# OR: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# 
# !!! NEVER use the default value in production !!!
JWT_SECRET=

# Default password for seeded admin accounts
# In production, set this to a strong unique password
# Leave empty to use fallback (development only)
ADMIN_DEFAULT_PASSWORD=

# ============================================
# EXTERNAL INTEGRATIONS
# ============================================
# Gemini AI API (for AI features)
GEMINI_API_KEY=

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=
RAZORPAY_SECRET=

# Telegram Alerts (for AI Overwatch)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Google OAuth (for backup features)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/api/backup/google/callback

# ============================================
# MONITORING & OBSERVABILITY
# ============================================
# Sentry Error Tracking
SENTRY_DSN=

# ============================================
# REDIS CACHE (Wolf Scale-Up Phase 2)
# ============================================
# Option 1: Upstash (Free - https://upstash.com)
# REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379

# Option 2: Redis Labs (Free - https://redis.com/try-free/)
# REDIS_URL=redis://default:xxx@redis-12345.cloud.redislabs.com:12345

# Option 3: Local Docker
# docker run -d --name wolf-redis -p 6379:6379 redis:alpine
# REDIS_URL=redis://localhost:6379

# Leave empty for in-memory cache (development)
REDIS_URL=

# ============================================
# MULTI-TENANCY
# ============================================
MASTER_DOMAIN=wolfsecurity.in

# ============================================
# RATE LIMITING
# ============================================
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=500
AUTH_RATE_LIMIT_WINDOW_MS=3600000
AUTH_RATE_LIMIT_MAX=1000

# ============================================
# CLINICAL SENTINEL (Health Monitoring)
# ============================================
CLINICAL_SENTINEL_INTERVAL_MS=300000

# ============================================
# WOLF VAULT (AES-256-GCM Encryption)
# ============================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WOLF_VAULT_MASTER_KEY=

# ============================================
# LIVEKIT (Video Calling - Wolf Video)
# ============================================
# Get from https://livekit.io or self-hosted
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=
